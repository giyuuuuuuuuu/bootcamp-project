{
  "version": 2,
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/health",
      "dest": "/api/[[...path]].js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...path]].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
